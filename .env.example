# 이 파일은 커밋용 템플릿입니다. 실제 값은 `.env`에 복사 후 수정하세요.
# 복사:  cp .env.example .env

# ------ Docker MySQL ------
# 호스트 포트는 23306으로 고정(컨테이너 내부는 3306)
MYSQL_HOST_PORT=23306
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=jpa_portfolio
MYSQL_USER=jpa
MYSQL_PASSWORD=jpa_password

# ------ Spring Boot (backend/src/main/resources/application.yml 에서 참조) ------
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:23306/jpa_portfolio?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul
SPRING_DATASOURCE_USERNAME=jpa
SPRING_DATASOURCE_PASSWORD=jpa_password

# ------ React (frontend/.env 에서 참조) ------
VITE_API_BASE_URL=http://localhost:8080
